# ─── Database ─────────────────────────────────────────────────────────────
#MONGO_URI=mongodb://localhost:27017/cpvoucher
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=<any_random_string_at_least_32_chars>

# ─── Environment ──────────────────────────────────────────────────────────
NODE_ENV=development

# ─── URLs ─────────────────────────────────────────────────────────────────
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ─── Email (Nodemailer - Gmail App Password) ──────────────────────────────
# Use an App Password, NOT your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your_gmail_address@gmail.com>
EMAIL_PASS=<your_16_char_app_password>

# ─── Gemini AI (for auto-generating voucher descriptions) ─────────────────
# Get a free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your_gemini_api_key>
GEMINI_MODEL=gemini-2.5-flash

# ─── Google OAuth 2.0 (for Sign in with Google) ───────────────────────────
# 1. Go to https://console.cloud.google.com/ → Create project
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web app)
# 3. Add authorized redirect URI: http://localhost:5000/api/auth/google/callback
# 4. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
